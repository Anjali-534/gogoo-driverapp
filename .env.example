# Backend API URL - use your machine's local IP when testing on a real device
EXPO_PUBLIC_API_URL=http://YOUR_MACHINE_IP:8080

# Google Maps API key - get from Google Cloud Console (still used for MapView tile rendering)
EXPO_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_api_key_here

# Ola Maps (Krutrim) API key - get from https://maps.olakrutrim.com/ (used for places/geocoding/directions)
EXPO_PUBLIC_OLA_MAPS_KEY=your_ola_maps_api_key_here
